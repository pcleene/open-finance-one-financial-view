# Acme One Financial View — POC environment. Copy to .env and fill in.
# Loaded from the repo root by backend/acme_ofv/config.py (12-factor, .env-driven).

# --- Atlas (this POC authenticates with X.509) ---
# Point at your own cluster; place your X.509 client cert PEM under secrets/.
ATLAS_URI=mongodb+srv://your-cluster.xxxxx.mongodb.net/?authSource=%24external&authMechanism=MONGODB-X509&appName=acme-ofv
ATLAS_CERT_PATH=secrets/atlas-x509.pem

# --- databases ---
DB_NAME=acme_ofv
MOCK_DB_NAME=ofp_mock

# --- consent event transport: direct (Mongo sink emulation) | kafka (MSK) ---
CONSENT_EVENT_TRANSPORT=direct

# --- mock OFP crypto envelope: off = readable JSON ---
OFP_CRYPTO=off

# --- API access control (defense-in-depth behind the ALB IP allow-list) ---
# Local dev: leave API_KEY empty and AUTH_REQUIRED unset (gate is a no-op).
# Deployed/public: set AUTH_REQUIRED=true AND a strong API_KEY (fail-closed).
# API_KEY must match frontend/.env API_KEY (injected server-side by the proxy).
API_KEY=
AUTH_REQUIRED=false
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# --- Voyage AI (transaction vector/hybrid search) — get a key at voyageai.com ---
VOYAGE_API_KEY=
VOYAGE_INDEX_MODEL=voyage-4-large
VOYAGE_QUERY_MODEL=voyage-4-lite
VOYAGE_RERANK_MODEL=rerank-2.5
VOYAGE_DIMENSIONS=1024

# --- Kafka / MSK (only used when CONSENT_EVENT_TRANSPORT=kafka) ---
KAFKA_BOOTSTRAP=
KAFKA_CONSENT_TOPIC=rcp.consent.events
KAFKA_AUTH=msk_iam
AWS_REGION=ap-southeast-1
