# Copy to frontend/.env to point the local UI at a deployed backend.
#
# Local (default — omit the file entirely): the client calls http://127.0.0.1:8010.
#
# Against AWS: route the UI through the Vite dev proxy at /api -> the ALB, so the
# browser stays same-origin (no CORS) and you see real end-to-end latency
# (browser -> ALB -> EC2 -> Atlas over PrivateLink). The ALB is HTTPS-only with a
# self-signed cert; the dev proxy accepts it server-side (`secure: false`).
BACKEND_URL=https://<your-alb-dns>.ap-southeast-1.elb.amazonaws.com
VITE_API_URL=/api
# Set this to match the API_KEY in the EC2 secret (acme-ofv/dev) once you
# enable the API auth gate. Server-side only (injected as X-API-Key by the proxy).
API_KEY=
